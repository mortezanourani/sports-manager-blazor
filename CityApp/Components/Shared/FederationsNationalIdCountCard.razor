@rendermode InteractiveServer

<div class="card bordered-card white-card wrapper">
    <div class="count-card">
        @if (federationsCount is null)
        {
            <Loading />
        }
        else
        {
            <svg width="140" height="140" viewBox="-5 -5 222 222" version="1.1" xmlns="http://www.w3.org/2000/svg" style="transform:rotate(-90deg)">
                <circle r="95" cx="105" cy="105" fill="transparent" stroke="lightgray" stroke-width="13"></circle>
                <circle r="95" cx="105" cy="105" stroke="var(--primary-color)" stroke-width="14" stroke-linecap="round" stroke-dashoffset="@string.Format("{0}px", percentPixels)" fill="transparent" stroke-dasharray="600px"></circle>
            </svg>
            <div class="count">
                <h3 class="header-3">@nationalIdsCount</h3>
            </div>
        }
    </div>
    <h5 class="card-title header-5">هیات های دارای شناسه</h5>
</div>

@code {
    private int? nationalIdsCount { get; set; }
    private int? federationsCount { get; set; }
    private int? percentPixels { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        federationsCount = null;
        using var context = DbFactory.CreateDbContext();

        var federations = await context.LocalFederations
            .Where(m => m.CityId == 4)
            .ToListAsync();
        federationsCount = federations
            .Count();
        nationalIdsCount = federations
            .Count(m => m.NationalId != null);
        percentPixels = (int)((1 - ((double)nationalIdsCount / federationsCount)) * 600);
    }
}