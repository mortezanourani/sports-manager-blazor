@using Microsoft.AspNetCore.Components.QuickGrid

@rendermode InteractiveServer

@if (Federations is null)
{
	<Loading CardMode=true />
}
else
{
	<div class="federations-list">
		<div class="list-header">
			<div class="header-year">
				<h6 class="title text-3">فهرست روسای هیات های شهرستان</h6>
			</div>
			@{
				var pageIndex = pagination.CurrentPageIndex;
				var currentPage = pageIndex + 1;
				var lastPage = pagination.LastPageIndex + 1;
				<div class="paginator">
					<nav role="navigation">
						<button @onclick="@(() => GoToPageAsync(pageIndex - 1))"
								aria-current="@AriaCurrentValue(pageIndex - 1)"
								aria-label="@(pageIndex - 1)"
								disabled=@((pageIndex <= 0) ? "disabled" : false)>
							<img src="/icons/arrow-right.svg" />
						</button>
						<button @onclick="@(() => GoToPageAsync(pageIndex + 1))"
								aria-current="@AriaCurrentValue(pageIndex + 1)"
								aria-label="@(pageIndex + 1)"
								disabled=@((currentPage >= lastPage) ? "disabled" : false)>
							<img src="/icons/arrow-left.svg" />
						</button>
					</nav>
				</div>
			}
		</div>
		<div class="counts-wrapper">
			<div class="federations-count">
				<div class="table-wrapper">
					@if (Federations is null)
					{
						<Loading CardMode="true" />
					}
					else
					{
						<QuickGrid Items="Federations.AsQueryable()" Theme="" Class="quickgrid-table" Pagination="@pagination">
							<PropertyColumn Class="title display-6" Property="@(federation => federation.Federation.PersianName)" />
							<PropertyColumn Class="item-count header-6 nationalid" Property="@(federation => federation.NationalId)" />
							<PropertyColumn Class="item-count type" Title="حکم" Property="@(federation => federation.LocalFederationPresidents.OrderByDescending(p => p.AppointmentDate).FirstOrDefault()!.IsPresident ? "رئیس" : "سرپرست")" />
							<PropertyColumn Class="item-count header-4 name" Property="@(federation => federation.LocalFederationPresidents.OrderByDescending(p => p.AppointmentDate).FirstOrDefault()!.Name)" />
						</QuickGrid>
					}
				</div>
			</div>
		</div>
	</div>
}

@code {
	private List<LocalFederation>? Federations;

	protected override async Task OnParametersSetAsync()
	{
		Federations = null;

		using var context = DbFactory.CreateDbContext();

		Federations = await context.LocalFederations
			.Include(federation => federation.Federation)
			.Include(federation => federation.LocalFederationPresidents)
			.OrderBy(federation => federation.Federation.PersianName)
			.ToListAsync();
	}

	private PaginationState pagination = new PaginationState { ItemsPerPage = 4 };

	private async Task GoToPageAsync(int pageIndex)
	{
		await pagination.SetCurrentPageIndexAsync(pageIndex);
	}

	private string? PageButtonClass(int pageIndex)
		=> pagination.CurrentPageIndex == pageIndex ? "current" : null;

	private string? AriaCurrentValue(int pageIndex)
		=> pagination.CurrentPageIndex == pageIndex ? "page" : null;
}
