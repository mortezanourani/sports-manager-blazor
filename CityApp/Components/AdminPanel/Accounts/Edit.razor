@page "/Panel/Accounts/Edit/{UserId}"

@using System.Security.Claims
@using Microsoft.AspNetCore.Identity
@using System.ComponentModel.DataAnnotations

@inject UserManager<CityUser> UserManager

@rendermode InteractiveServer

<AuthorizeView Policy="FullAccess" Context="AuthContext">
    <div class="row form-wrapper">
        <div class="col3-5 mb-0">
            <h6 class="display-4 mb-3">ویرایش مشخصات</h6>
            <div class="instructions">
                <p class="mb-3">در این بخش می توانید پرسنل جدیدی را تعریف کنید. با تعریف پرسنل جدید یک حساب کاربری برای فرد مذکور ساخته می شود. نام کاربری و رمزعبور برای کارمند مورد نظر برابر کد ملی او خواهد بود.</p>
                <div class="instruction-item">
                    <div class="icon-title mb-2">
                        <img src="/icons/idcard-blue.svg">
                        <h6>کد ملی:</h6>
                    </div>
                    <p>کد ملی به صورت ده رقمی بدون خط تیره یا علامت دیگری وارد گردد.</p>
                </div>
                <div class="instruction-item">
                    <div class="icon-title mb-2">
                        <img src="/icons/user-blue.svg">
                        <h6>نام</h6>
                        <img src="/icons/group-blue.svg">
                        <h6>نام خانوادگی:</h6>
                    </div>
                    <p>نام و نام خانوادگی به صورت جداگانه در دو فیلد مجزا وارد می گردد.</p>
                </div>
                <div class="instruction-item">
                    <div class="icon-title mb-2">
                        <img src="/icons/genders-blue.svg">
                        <h6>جنسیت:</h6>
                    </div>
                    <p>جنسیت از منوی کشویی تایین می گردد.</p>
                </div>
                <div class="instruction-item">
                    <div class="icon-title mb-2">
                        <img src="/icons/calendar-blue.svg">
                        <h6>تاریخ تولد:</h6>
                    </div>
                    <p>تاریخ تولد به ترتیب از چپ به راست با عدد چهار رقمی سال، عدد دو رقمی ماه و دو رقمی روز که با خط تیره از هم جدا شده باشند ثبت می شود.</p>
                </div>
                <div class="instruction-item">
                    <div class="icon-title mb-2">
                        <img src="/icons/father-blue.svg">
                        <h6>نام پدر:</h6>
                    </div>
                    <p>نام پدر در این فرم الزامی نمی باشد.</p>
                </div>
                <div class="instruction-item">
                    <div class="icon-title mb-2">
                        <img src="/icons/employment-blue.svg">
                        <h6>نوع قرارداد:</h6>
                    </div>
                    <p>عنوان قرارداد پرسنل از طریق منوی کشویی قابل انتخاب خواهد بود.</p>
                </div>
                <div class="instruction-item">
                    <div class="icon-title mb-2">
                        <img src="/icons/badge-blue.svg">
                        <h6>کد پرسنلی:</h6>
                    </div>
                    <p>کد پرسنلی الزامی نمی باشد، بنابراین چنانچه پرسنلی هنوز کد پرسنلی دریافت نکرده باشد می توانید این بخش را خالی بگذارید.</p>
                </div>
            </div>
        </div>
        <div class="col2-5 mb-auto">
            @if (User is null)
            {
                <Loading CardMode=true />
            }
            else
            {
                <div class="card bordered-card">
                    <EditForm method="post" Model="User" OnValidSubmit="UpdateUser" FormName="edit" Enhance>
                        <DataAnnotationsValidator />
                        <ValidationSummary class="text-danger" role="alert" />
                        <input type="hidden" name="User!.Id" value="@UserId!" />
                        <div class="form-group en mb-3">
                            <label for="seencode" class="form-label">
                                <img src="/icons/idcard.svg" />
                            </label>
                            <InputText id="seencode" @bind-Value="User!.UserName" class="form-control" placeholder="کد ملی" />
                        </div>
                        <div class="form-row">
                            <div class="form-group fa mb-3">
                                <label for="firstname" class="form-label">
                                    <img src="/icons/user.svg" />
                                </label>
                                <InputText id="firstname" @bind-Value="User.FirstName" class="form-control" placeholder="نام" />
                            </div>
                            <div class="form-group fa mb-3">
                                <label for="lastname" class="form-label">
                                    <img src="/icons/group.svg" />
                                </label>
                                <InputText id="lastname" @bind-Value="User.LastName" class="form-control" placeholder="نام خانوداگی" />
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group fa mb-3">
                                <label for="genderid" class="form-label">
                                    <img src="/icons/genders.svg" />
                                </label>
                                <InputSelect id="genderid" class="select form-control" @bind-Value="User!.GenderId">
                                    @if (Genders is not null)
                                    {
                                        foreach (Gender gender in Genders)
                                        {
                                            <option value="@gender.Id">@gender.PersianName</option>
                                        }
                                    }
                                </InputSelect>
                            </div>
                            <div class="form-group en mb-3">
                                <label for="birthdate" class="form-label">
                                    <img src="/icons/calendar.svg" />
                                </label>
                                <InputText id="birthdate" @bind-Value="User.BirthDate" class="form-control" placeholder="1300-01-01 [تاریخ تولد]" />
                            </div>
                        </div>
                        <div class="form-row">
                            <div class="form-group fa mb-3">
                                <label for="fathername" class="form-label">
                                    <img src="/icons/father.svg" />
                                </label>
                                <InputText id="fathername" @bind-Value="User.FatherName" class="form-control" placeholder="نام پدر" />
                            </div>
                            <div class="form-group en mb-3">
                                <label for="phonenumber" class="form-label">
                                    <img src="/icons/phone.svg" />
                                </label>
                                <InputText id="phonenumber" @bind-Value="User.PhoneNumber" class="form-control" placeholder="تلفن همراه" />
                            </div>
                        </div>
                        <div class="form-group en mb-3">
                            <label for="personnelid" class="form-label">
                                <img src="/icons/badge.svg" />
                            </label>
                            <InputText id="personnelid" @bind-Value="User.PersonnelId" class="form-control" placeholder="کد پرسنلی" />
                        </div>
                        @if (!string.IsNullOrEmpty(statusMessage))
                        {
                            <div class="alert alert-@statusMessageClass" role="alert">
                                @statusMessage
                            </div>
                        }
                        <button type="submit" class="btn btn-primary w-100">ثبت</button>
                    </EditForm>
                    <a class="btn btn-danger p-2 mt-3" href="/Panel/Accounts/Delete/@UserId">حذف کاربر</a>
                </div>
            }
        </div>
    </div>
</AuthorizeView>

@code {
    [Parameter]
    public string? UserId { get; set; }

    private string? statusMessage;
    private string? statusMessageClass;

    [SupplyParameterFromForm]
    private CityUser? User { get; set; }

    private List<Gender>? Genders;

    protected override async Task OnInitializedAsync()
    {
        using var context = DbFactory.CreateDbContext();

        Genders = await context.Genders.ToListAsync();

        User ??= await UserManager.Users
            .Include(u => u.Gender)
            .FirstOrDefaultAsync(u => u.Id == UserId);

        if (User is null)
        {
            NavigationManager.NavigateTo("/Panel/Accounts");
        }
    }

    private async Task UpdateUser()
    {
        var user = await UserManager.Users
            .Include(u => u.Gender)
            .FirstOrDefaultAsync(u => u.Id == UserId!);

        user.UserName = User!.UserName!;
        user.FirstName = User.FirstName;
        user.LastName = User.LastName;
        user.GenderId = User.GenderId;
        user.BirthDate = User.BirthDate;
        user.FatherName = User.FatherName;
        user.PhoneNumber = User.PhoneNumber;
        user.PersonnelId = User.PersonnelId;

        try
        {
            await UserManager.UpdateAsync(user!);
            statusMessageClass = "success";
            statusMessage = $"ویرایش اطلاعات با موفقیت انجام شد.";
        }
        catch (DbUpdateConcurrencyException exception)
        {
            statusMessageClass = "danger";
            statusMessage = $"{exception.Message}";
        }

        return;
    }

    private async Task DeleteUser(string UserId)
    {
        CityUser? user = await UserManager.FindByIdAsync(UserId!);
        if (user is null) return;

        try
        {
            await UserManager.DeleteAsync(user);
            NavigationManager.NavigateTo("/Panel/Accounts");
        }
        catch(Exception exception)
        {
            statusMessageClass = "danger";
            statusMessage = $"{exception.Message}";
        }
        return;
    }
}
