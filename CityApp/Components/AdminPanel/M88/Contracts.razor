@using Microsoft.AspNetCore.Components.QuickGrid

@page "/Panel/M88/Contracts"

@rendermode InteractiveServer

@layout _Layout

<PageTitle>قراردادهای واگذاری</PageTitle>

<div class="list-wrapper">
	<div class="list-header">
		<div class="header-title colored">
			<h6 class="title">فهرست قرادادهای واگذاری اماکن دولتی @City?.PersianName</h6>
			<div class="search form-group fa">
				<label class="form-label" for="paginator-search-input">
					<img src="/icons/search-gray.svg" />
				</label>
				<InputText class="form-control" placeholder="جستجو" id="paginator-search-input" @bind-Value="searchText" @oninput="SearchName"></InputText>
			</div>
		</div>
		<div class="paginator">
			<nav role="navigation">
				@if (pagination.TotalItemCount.HasValue)
				{
					var totalPages = pagination.TotalItemCount;
					var pageIndex = pagination.CurrentPageIndex;
					var currentPage = pageIndex + 1;
					var lastPage = pagination.LastPageIndex + 1;
					var firstItemNumber = 1 + (pagination.ItemsPerPage * pagination.CurrentPageIndex);
					var lastItemNumber = pagination.ItemsPerPage * (pagination.CurrentPageIndex + 1);
					<button @onclick="@(() => GoToPageAsync(pageIndex - 1))"
							aria-current="@AriaCurrentValue(pageIndex - 1)"
							aria-label="@(pageIndex - 1)"
							disabled=@((pageIndex <= 0) ? "disabled" : false)>
						<img src="/icons/arrow-right.svg" />
					</button>
					<button @onclick="@(() => GoToPageAsync(pageIndex + 1))"
							aria-current="@AriaCurrentValue(pageIndex + 1)"
							aria-label="@(pageIndex + 1)"
							disabled=@((currentPage >= lastPage) ? "disabled" : false)>
						<img src="/icons/arrow-left.svg" />
					</button>
				}
			</nav>
		</div>
	</div>
	<div class="table-wrapper">
		@if (FacilitiesContracts is null)
		{
			<Loading CardMode=true />
		}
		else
		{
			<QuickGrid Items="FacilitiesContracts.AsQueryable()" Pagination="pagination" Theme="">
				<TemplateColumn Class="action-button status" Title="مجوز ماده 5">
					@if (!string.IsNullOrEmpty(context.LicenseSerial))
					{
						<img src="/icons/verified.svg" />
					}
					else
					{
						<img src="/icons/verified-off.svg" />
					}
				</TemplateColumn>
				<PropertyColumn Class="light text-3" Title="شماره قرارداد" Property="@(contract => contract.Serial!)" />
				<PropertyColumn Class="bold header-5" Title="نام موسس" Property="@(contract => contract.Name!)" />
				<PropertyColumn Class="light text-3" Title="کد ملی موسس" Property="@(contract => contract.SeenCode!)" />
				<PropertyColumn Class="light text-3" Title="شماره همراه موسس" Property="@(contract => contract.Phone!)" />
				<PropertyColumn Class="light text-3" Title="تاریخ تاسیس" Property="@(contract => contract.StartDate!)" />
				<PropertyColumn Class="light text-3 text-red" Title="تاریخ انقضا" Property="@(contract => contract.ExpireDate!)" />
				<TemplateColumn Class="action-button">
					<a class="edit-link" href="/Panel/M88/Contracts/Edit/@context.Id">
						<img src="/icons/note-edit.svg" />
					</a>
				</TemplateColumn>
			</QuickGrid>
		}
	</div>
</div>

@code {
	private int CityId = 4;

	private City? City;

	private List<FacilityContract>? FacilitiesContracts { get; set; }

	private string? searchText;

	protected override async Task OnInitializedAsync()
	{
		using var context = DbFactory.CreateDbContext();

		City = await context.Cities
			.FirstOrDefaultAsync(m => m.Id == CityId);

		await UpdateList();
	}

	private async Task SearchName(ChangeEventArgs args)
	{
		searchText = args.Value!.ToString();

		using var context = DbFactory.CreateDbContext();

		List<FacilityContract> contracts = await context.Facilities
			.SelectMany(m => m.FacilityContracts)
			.OrderByDescending(m => m.ExpireDate)
			.ToListAsync();

		FacilitiesContracts = string.IsNullOrEmpty(searchText)
			? contracts
			: contracts
				.Where(contract =>
					contract.Name.Contains(searchText)
				// ||
				// contract.Facility.Name.Contains(searchText)
				)
				.OrderByDescending(contract => contract.ExpireDate)
				.ToList();
	}

	private async Task UpdateList()
	{
		FacilitiesContracts = null;
		searchText = string.Empty;

		using var context = DbFactory.CreateDbContext();

		FacilitiesContracts = await context.Facilities
			.SelectMany(m => m.FacilityContracts)
			.OrderByDescending(m => m.ExpireDate)
			.ToListAsync();

		await pagination.SetCurrentPageIndexAsync(0);
		pagination.TotalItemCountChanged += (sender, eventArgs) => StateHasChanged();

		StateHasChanged();
	}

	private PaginationState pagination = new PaginationState { ItemsPerPage = 5 };

	private async Task GoToPageAsync(int pageIndex)
	{
		await pagination.SetCurrentPageIndexAsync(pageIndex);
	}

	private string? AriaCurrentValue(int pageIndex)
		=> pagination.CurrentPageIndex == pageIndex ? "page" : null;
}
