@using Microsoft.AspNetCore.Components.QuickGrid

@page "/Panel/Orgs"

@rendermode InteractiveServer

@layout _Layout

<PageTitle>اماکن سایر ارگان ها</PageTitle>

<div class="list-wrapper">
	<div class="list-header">
		<div class="header-title colored">
			<h6 class="title">فهرست اماکن ورزشی سایر ارگان های شهرستان</h6>
			<div class="search form-group fa">
				<label class="form-label" for="paginator-search-input">
					<img src="/icons/search-gray.svg" />
				</label>
				<InputText class="form-control" placeholder="جستجو" id="paginator-search-input" @bind-Value="searchText" @oninput="SearchName"></InputText>
			</div>
		</div>
		<div class="paginator">
			<nav role="navigation">
				@if (pagination.TotalItemCount.HasValue)
				{
					var totalPages = pagination.TotalItemCount;
					var pageIndex = pagination.CurrentPageIndex;
					var currentPage = pageIndex + 1;
					var lastPage = pagination.LastPageIndex + 1;
					var firstItemNumber = 1 + (pagination.ItemsPerPage * pagination.CurrentPageIndex);
					var lastItemNumber = pagination.ItemsPerPage * (pagination.CurrentPageIndex + 1);
					<button @onclick="@(() => GoToPageAsync(pageIndex - 1))"
							aria-current="@AriaCurrentValue(pageIndex - 1)"
							aria-label="@(pageIndex - 1)"
							disabled=@((pageIndex <= 0) ? "disabled" : false)>
						<img src="/icons/arrow-right.svg" />
					</button>
					<button @onclick="@(() => GoToPageAsync(pageIndex + 1))"
							aria-current="@AriaCurrentValue(pageIndex + 1)"
							aria-label="@(pageIndex + 1)"
							disabled=@((currentPage >= lastPage) ? "disabled" : false)>
						<img src="/icons/arrow-left.svg" />
					</button>
				}
			</nav>
		</div>
	</div>
	<div class="table-wrapper">
		@if (Facilities is null)
		{
			<Loading CardMode=true />
		}
		else
		{
			@if (Facilities is not null)
			{
				<QuickGrid Items="Facilities.AsQueryable()" Pagination="pagination" Theme="" Class="quickgrid-table">
					<TemplateColumn Class="action-button status">
						@if (context.IsActive)
						{
							<img src="/icons/verified.svg" />
						}
						else
						{
							<img src="/icons/verified-off.svg" />
						}
					</TemplateColumn>
					<PropertyColumn Class="title header-5" Title="عنوان مکان ورزشی" Property="@(facility => facility.Name)" />
					<PropertyColumn Class="text-3" Title="موقعیت جغرافیایی" Property="@(facility => facility.IsRural == true ? "روستایی" : "شهری")" />
					<PropertyColumn Class="text-3" Title="مساحت" Property="@(facility => facility.Area)" />
					<PropertyColumn Class="text-3" Title="مساحت روباز" Property="@(facility => facility.SportLandArea)" />
					<PropertyColumn Class="text-3" Title="مساحت سرپوشیده" Property="@(facility => facility.SportHallArea)" />
					<TemplateColumn Class="action-button">
						<a class="edit-link" href="/Panel/Orgs/Edit/@context.Id">
							<img src="/icons/square-edit.svg" />
						</a>
					</TemplateColumn>
				</QuickGrid>
			}
		}
	</div>
</div>

@code {
	private List<GovernmentFacility>? Facilities { get; set; }

	private string? searchText;

	protected override async Task OnInitializedAsync()
	{
		using var context = DbFactory.CreateDbContext();

		await UpdateList();
	}

	private async Task SearchName(ChangeEventArgs args)
	{
		searchText = args.Value!.ToString();

		using var context = DbFactory.CreateDbContext();

		var facilities = await context.GovernmentFacilities
				.Include(facility => facility.Type)
				.Include(facility => facility.GovernmentFacilityLicenses)
				.OrderBy(facility => facility.Name)
				.ToListAsync();

		Facilities = string.IsNullOrEmpty(searchText)
			? facilities
			: facilities
				.Where(facility =>
					facility.Name.Contains(searchText)
					||
					facility.GovernmentFacilityLicenses
						.Any(license => license.Name.Contains(searchText))
				)
				.OrderBy(facility => facility.Name)
				.ToList();
	}

	private async Task UpdateList()
	{
		Facilities = null;
		searchText = string.Empty;

		using var context = DbFactory.CreateDbContext();

		Facilities = await context.GovernmentFacilities
				.Include(facility => facility.Type)
				.Include(facility => facility.GovernmentFacilityLicenses)
				.OrderBy(facility => facility.Name)
				.ToListAsync();

		await pagination.SetCurrentPageIndexAsync(0);
		pagination.TotalItemCountChanged += (sender, eventArgs) => StateHasChanged();

		StateHasChanged();
	}

	private PaginationState pagination = new PaginationState { ItemsPerPage = 6 };

	private async Task GoToPageAsync(int pageIndex)
	{
		await pagination.SetCurrentPageIndexAsync(pageIndex);
	}

	private string? AriaCurrentValue(int pageIndex)
		=> pagination.CurrentPageIndex == pageIndex ? "page" : null;
}
